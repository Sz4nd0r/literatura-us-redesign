{% extends "./base.njk" %}

{% block content %}
  <article class="max-w-4xl mx-auto py-4 px-0.5 min-h-screen">
    <div class="bg-white shadow-2xl border border-gray-100 p-4 lg:p-12 mb-12 rounded-none relative">      
      <header class="mb-12 border-b border-gray-100 pb-8">
        <h1 class="title_style">{{ title }}</h1>
        <div class="w-24 h-1 bg-blue-600"></div>
      </header>

      <div class="reader-content prose prose-lg prose-slate max-w-none" id="reader-author">
        {{ content | safe }}
      </div>
    </div>

    <section class="mt-20">
      <h2 class="title_style text-xl sm:text-2xl flex items-center">
        <span class="button_style bg-gray-900 text-white px-3 py-1 mr-4">Obras</span>
        Obras disponibles
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for work in collections.works %}
          {% if work.tags[1] == slug or work.tags[1] == tags[1] %}
            <a href="{{ work.url }}" class="card_style">
              <span class="text-gray-800 font-medium">{{ work.title }}</span>
              <span class="text-gray-300 ml-auto">&rarr;</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  </article>
{% endblock %}

