{% extends "./base.njk" %}

{% block content %}
<article>
  <header>
    <h1>{{ title }}</h1>
  </header>
  
  <div class="reader-content" id="reader-story">
    {{ content | safe }}
  </div>

  <hr>
  <p><a href="/content/authors/{{ tags[1] }}/">Volver al autor</a></p>
</article>
{% endblock %}

{% block scripts %}
  <script src="/assets/js/formatter.js"></script>
{% endblock %}
