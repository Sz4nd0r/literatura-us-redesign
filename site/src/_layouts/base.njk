<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Literatura.us 2.0</title>
  <link rel="stylesheet" href="/assets/css/index.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body class="bg-[#f4f1ea] text-[#2c2c2c] min-h-screen">
  <header class="sticky top-0 z-50 bg-white shadow-xl py-4 px-8 border-b border-gray-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <h1><a href="/" class="text-2xl font-bold tracking-tight hover:text-gray-600 transition-colors">Literatura.us 2.0</a></h1>
      <nav>
        <ul class="flex space-x-6 text-sm font-medium uppercase tracking-wider">
          <li><a href="/" class="hover:text-blue-600 transition-colors">Inicio</a></li>
          <!-- Add more nav items as needed -->
        </ul>
      </nav>
    </div>
  </header>

  <main>
    {% block content %}
      {{ content | safe }}
    {% endblock %}
  </main>

  <footer>
    <p>&copy; 2026 Literatura.us 2.0 - Modernizando la biblioteca personal.</p>
  </footer>

  {% block scripts %}{% endblock %}
</body>
</html>
